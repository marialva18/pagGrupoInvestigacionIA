# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_TIMEZONE=America/Lima

# -----------------------------------------------------------------------------
# Web pública
# Solo variables PUBLIC_* son visibles en el navegador.
# -----------------------------------------------------------------------------
PUBLIC_WEB_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:3001/api/v1
API_INTERNAL_URL=http://localhost:3001/api/v1

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=3001
WEB_ORIGINS=http://localhost:4321
TRUST_PROXY=false
LOG_LEVEL=info
ENABLE_EDITOR_ROUTES=true

# -----------------------------------------------------------------------------
# PostgreSQL / Supabase
# No colocar datos reales en el repositorio.
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=intgarti-media
AUTH_INVITE_REDIRECT_URL=http://localhost:4321/auth/aceptar-invitacion
AUTH_PASSWORD_RESET_REDIRECT_URL=http://localhost:4321/auth/restablecer-contrasena

# -----------------------------------------------------------------------------
# Correo transaccional
# Brevo SMTP se configura directamente en Supabase Authentication.
# Las credenciales SMTP no deben guardarse en esta aplicación.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Bootstrap único del primer administrador
# No colocar una contraseña en este archivo.
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
SESSION_SECRET=
ANALYTICS_HASH_SECRET=

# -----------------------------------------------------------------------------
# Analítica
# -----------------------------------------------------------------------------
ANALYTICS_ENABLED=true
# -----------------------------------------------------------------------------
# Almacenamiento de imágenes
# MinIO se usa únicamente durante el desarrollo local.
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=intgarti
S3_SECRET_KEY=intgarti_dev_storage
S3_BUCKET=intgarti-media
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=intgarti
MINIO_ROOT_PASSWORD=intgarti_dev_storage
IMAGE_WORKER_POLL_MS=5000
IMAGE_MAX_PIXELS=16000000
ENABLE_IMAGE_WORKER=false
IMAGE_WORKER_MAX_JOBS_PER_PROCESS=1
IMAGE_WORKER_RESTART_DELAY_MS=10000
MALLOC_ARENA_MAX=2
