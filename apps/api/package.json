{
  "name": "@intgarti/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/health.test.ts tests/security-routes.test.ts tests/http-contract.test.ts tests/media-upload.test.ts tests/news.test.ts tests/auth.test.ts tests/admin-users.test.ts tests/members.test.ts tests/public-content.test.ts tests/external-news.test.ts",
    "auth:provision-user": "tsx src/scripts/provision-cms-user.ts",
    "auth:smoke": "tsx src/scripts/auth-smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@intgarti/contracts": "workspace:*",
    "@intgarti/database": "workspace:*",
    "@supabase/supabase-js": "^2.110.7",
    "compression": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "pino": "latest",
    "pino-http": "latest",
    "zod": "latest",
    "@intgarti/news-ingestion": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/compression": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "typescript": "6.0.3",
    "typescript-eslint": "latest"
  }
}
