---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="El grupo | INTGARTI">
  <main class="page">
    <span>INTGARTI</span>
    <h1>El grupo</h1>
    <p>Información institucional, objetivos y líneas de investigación.</p>
    <a href="/">← Volver al inicio</a>
  </main>
</BaseLayout>

<style>
  .page {
    width: min(calc(100% - 40px), 900px);
    margin-inline: auto;
    padding: 90px 0;
  }

  span {
    color: var(--color-burgundy);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  h1 {
    margin: 18px 0;
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 500;
    line-height: 0.95;
  }

  p {
    max-width: 680px;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  a {
    display: inline-block;
    margin-top: 28px;
    padding-bottom: 3px;
    border-bottom: 1px solid currentColor;
    color: var(--color-burgundy);
    font-weight: 700;
  }
</style>
