---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/public/Footer.astro';
import Header from '../components/public/Header.astro';
import { listPublicNews } from '../services/api/news.api';
import {
  institutionProfileSchema,
  publicAcademicSourceSchema,
  publicMemberSchema,
} from '@intgarti/contracts';
import { z } from 'zod';
import { apiRequest } from '../lib/api-client';

const newsResult = await listPublicNews({ pageSize: 4 }).catch(() => ({
  items: [],
  pagination: {
    page: 1,
    pageSize: 4,
    total: 0,
    totalPages: 0,
    hasPreviousPage: false,
    hasNextPage: false,
  },
}));

const featuredNews = newsResult.items.find((item) => item.featured) ?? newsResult.items[0] ?? null;
const recentNews = newsResult.items.filter((item) => item.id !== featuredNews?.id).slice(0, 3);

function formatNewsDate(value: string | null): string {
  if (!value) return 'FECHA PENDIENTE';

  return new Intl.DateTimeFormat('es-PE', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    timeZone: 'America/Lima',
  })
    .format(new Date(value))
    .replace('.', '')
    .toUpperCase();
}

function newsHref(news: (typeof newsResult.items)[number]): string {
  return news.origin === 'EXTERNAL' && news.source.url ? news.source.url : `/noticias/${news.slug}`;
}

function externalLinkAttributes(news: (typeof newsResult.items)[number]) {
  return news.origin === 'EXTERNAL' && news.source.url
    ? { target: '_blank', rel: 'noopener noreferrer' }
    : {};
}

const [sources, members, institution] = await Promise.all([
  apiRequest('/public/academic-sources', z.array(publicAcademicSourceSchema)).catch(() => []),
  apiRequest('/public/members', z.array(publicMemberSchema)).catch(() => []),
  apiRequest('/public/institution', institutionProfileSchema).catch(() => null),
]);
const coordinator = members.find((member) => member.isCoordinator) ?? members[0] ?? null;
---

<BaseLayout>
  <Header />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow">Facultad de Ingeniería de Sistemas e Informática · UNMSM</span>
        <h1>
          INTGARTI
          <small>Grupo de Investigación en Inteligencia Artificial</small>
        </h1>
        <p>
          Información institucional, actividades, publicaciones y recursos académicos para la
          comunidad universitaria.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/noticias">Ver noticias</a>
          <a class="button secondary" href="/grupo">Conocer el grupo</a>
        </div>
      </div>

      {
        institution?.heroMedia ? (
          <img
            class="hero-photo-image"
            src={institution.heroMedia.url}
            alt={institution.heroMedia.altText ?? 'INTGARTI'}
          />
        ) : (
          <div class="hero-photo">
            <strong>Fotografía institucional</strong>
          </div>
        )
      }
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <div>
            <span class="label">Noticias y publicaciones</span>
            <h2>Información reciente, ordenada por relevancia.</h2>
          </div>
          <a class="history-link" href="/noticias">Ver historial de noticias →</a>
        </div>

        <div class="news-layout">
          <article class="featured-news">
            <span>Publicación destacada</span>
            {
              featuredNews ? (
                <>
                  <h3>
                    <a
                      class="news-title-link"
                      href={newsHref(featuredNews)}
                      {...externalLinkAttributes(featuredNews)}
                    >
                      {featuredNews.title}
                    </a>
                  </h3>
                  <p>
                    {featuredNews.summary ?? 'Publicación seleccionada por el equipo editorial.'}
                  </p>
                  <div class="featured-meta">
                    <span>{featuredNews.source.name}</span>
                    <time datetime={featuredNews.publishedAt ?? undefined}>
                      {formatNewsDate(featuredNews.publishedAt)}
                    </time>
                    <a href={newsHref(featuredNews)} {...externalLinkAttributes(featuredNews)}>
                      {featuredNews.origin === 'EXTERNAL'
                        ? 'Leer en la fuente →'
                        : 'Leer publicación →'}
                    </a>
                  </div>
                </>
              ) : (
                <>
                  <h3>Las publicaciones aparecerán después de ser aprobadas.</h3>
                  <p>El equipo editorial todavía no ha publicado una noticia destacada.</p>
                  <div class="featured-meta">
                    <span>INTGARTI</span>
                    <span>Contenido pendiente</span>
                    <a href="/editor/publicaciones">Administrar noticias →</a>
                  </div>
                </>
              )
            }
          </article>

          <div class="news-list">
            {
              recentNews.length > 0 ? (
                recentNews.map((item) => (
                  <article>
                    <div>
                      <span>{item.source.name}</span>
                      <time datetime={item.publishedAt ?? undefined}>
                        {formatNewsDate(item.publishedAt)}
                      </time>
                    </div>
                    <h3>
                      <a
                        class="news-title-link"
                        href={newsHref(item)}
                        {...externalLinkAttributes(item)}
                      >
                        {item.title}
                      </a>
                    </h3>
                  </article>
                ))
              ) : (
                <article>
                  <div>
                    <>
                      <span>INTGARTI</span>
                      <span>Sin publicaciones recientes</span>
                    </>
                  </div>
                  <h3>Las noticias aprobadas se mostrarán automáticamente en esta sección.</h3>
                </article>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section sources" id="fuentes-academicas">
      <div class="container">
        <span class="label light">Explora investigación</span>
        <h2>Busca publicaciones en fuentes académicas.</h2>
        <p>Fuentes seleccionadas para apoyar la búsqueda y producción científica.</p>

        <div class="source-grid">
          {
            sources.slice(0, 4).map((source, index) => (
              <a href={source.url} target="_blank" rel="noopener noreferrer">
                <span>0{index + 1}</span>
                <h3>{source.name}</h3>
                <p>{source.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section ivory">
      <div class="container split">
        <div>
          <span class="label">Sobre INTGARTI</span>
          <h2>Investigación organizada y aplicada.</h2>
        </div>
        <div class="lines">
          <p>{institution?.objectives}</p>
          {institution?.researchLines.map((line) => <div>{line.name}</div>)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <span class="label">Miembros</span>
        <h2>Coordinación y equipo de investigación.</h2>

        <div class="member-layout">
          {
            coordinator?.photoMedia ? (
              <img
                class="member-photo-image"
                src={coordinator.photoMedia.url}
                alt={coordinator.photoMedia.altText ?? coordinator.fullName}
              />
            ) : (
              <div class="member-photo">Fotografía del coordinador</div>
            )
          }
          <div class="member-list">
            <article>
              <strong>{coordinator?.fullName ?? 'Coordinador de INTGARTI'}</strong>
              <span>{coordinator?.roleTitle ?? 'Perfil institucional'}</span>
            </article>
            <article>
              <strong>{members.length} miembros publicados</strong>
              <span><a href="/miembros">Consultar directorio completo →</a></span>
            </article>
            <article>
              <strong>Perfiles académicos</strong>
              <span>ORCID, Google Scholar y otros enlaces.</span>
            </article>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero {
    display: grid;
    min-height: 650px;
    grid-template-columns: minmax(0, 0.92fr) minmax(480px, 1.08fr);
    background: var(--color-ivory);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 76px 70px 82px max(24px, calc((100vw - var(--content-width)) / 2));
  }

  .eyebrow,
  .label {
    display: block;
    margin-bottom: 18px;
    color: var(--color-burgundy);
    font-size: 0.73rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 500;
  }

  h1 {
    color: var(--color-navy);
    font-size: clamp(4rem, 7vw, 7rem);
    letter-spacing: -0.055em;
    line-height: 0.88;
  }

  h1 small {
    display: block;
    max-width: 580px;
    margin-top: 26px;
    font-family: var(--font-body);
    font-size: 0.22em;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.28;
  }

  .hero-copy > p {
    max-width: 620px;
    margin: 26px 0 34px;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    padding: 0 22px;
    border: 1px solid transparent;
    border-radius: 0;
    font-weight: 700;
  }

  .primary {
    color: var(--color-white);
    background: var(--color-burgundy);
  }

  .secondary {
    color: var(--color-navy);
    border-color: var(--color-navy);
  }

  .hero-photo,
  .member-photo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    color: rgb(255 255 255 / 75%);
    background: var(--color-navy-medium);
  }

  .hero-photo-image,
  .member-photo-image {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
  }

  .hero-photo span {
    margin-top: 8px;
    font-size: 0.82rem;
    opacity: 0.72;
  }

  .section {
    padding: 102px 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 46px;
  }

  h2 {
    max-width: 780px;
    color: var(--color-navy);
    font-size: clamp(2rem, 3.2vw, 3.2rem);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .history-link {
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    color: var(--color-navy);
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .news-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(290px, 0.75fr);
    gap: 36px;
    align-items: stretch;
  }

  .featured-news {
    display: flex;
    min-height: 470px;
    flex-direction: column;
    padding: 44px;
    color: var(--color-white);
    background: var(--color-navy);
  }

  .featured-news > span {
    color: #d9bb83;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .featured-news h3 {
    max-width: 610px;
    margin-top: auto;
    padding-top: 74px;
    font-size: clamp(1.9rem, 2.7vw, 2.85rem);
    letter-spacing: -0.035em;
    line-height: 1.06;
  }

  .news-title-link,
  .news-title-link:link,
  .news-title-link:visited,
  .news-title-link:hover,
  .news-title-link:active {
    border-bottom: 0;
    color: inherit;
    text-decoration: none !important;
    text-decoration-line: none !important;
  }

  .featured-news p {
    max-width: 570px;
    margin: 18px 0 0;
    color: rgb(255 255 255 / 68%);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .featured-meta {
    display: flex;
    margin-top: 26px;
    align-items: center;
    gap: 18px;
    color: rgb(255 255 255 / 72%);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .featured-meta a {
    margin-left: auto;
    padding-bottom: 3px;
    border-bottom: 1px solid currentColor;
    color: var(--color-white);
  }

  .news-list {
    border-top: 1px solid var(--color-line);
  }

  .news-list article {
    padding: 25px 0;
    border-bottom: 1px solid var(--color-line);
  }

  .news-list article > div {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .news-list h3 {
    margin-top: 10px;
    color: var(--color-navy);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .sources {
    color: var(--color-white);
    background: var(--color-navy);
  }

  .sources h2 {
    color: var(--color-white);
  }

  .sources > .container > p {
    max-width: 680px;
    color: rgb(255 255 255 / 68%);
  }

  .light {
    color: #d9bb83;
  }

  .source-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 46px;
  }

  .source-grid article,
  .source-grid > a {
    display: flex;
    min-height: 340px;
    flex-direction: column;
    justify-content: flex-end;
    padding: 30px;
    background: var(--color-navy-medium);
  }

  .source-grid article:first-child,
  .source-grid > a:first-child {
    background: var(--color-burgundy);
  }

  .source-grid article:nth-child(3),
  .source-grid > a:nth-child(3) {
    color: var(--color-text);
    background: var(--color-ivory);
  }

  .source-grid article > span,
  .source-grid > a > span {
    margin-bottom: auto;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .source-grid h3 {
    font-size: 2rem;
  }

  .source-grid p {
    opacity: 0.7;
  }

  .ivory {
    background: var(--color-ivory);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 80px;
  }

  .lines {
    color: var(--color-muted);
  }

  .lines div {
    padding: 20px 0;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: 1.4rem;
  }

  .member-layout {
    display: grid;
    grid-template-columns: minmax(320px, 0.8fr) minmax(0, 1.2fr);
    gap: 64px;
    margin-top: 48px;
  }

  .member-photo {
    min-height: 500px;
  }

  .member-list {
    border-top: 1px solid var(--color-line);
  }

  .member-list article {
    display: grid;
    padding: 25px 0;
    border-bottom: 1px solid var(--color-line);
  }

  .member-list strong {
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 500;
  }

  .member-list span {
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .hero,
    .news-layout,
    .split,
    .member-layout {
      grid-template-columns: 1fr;
    }

    .hero-photo {
      min-height: 480px;
    }

    .source-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero-copy {
      padding: 64px 22px;
    }

    .hero-photo {
      min-height: 380px;
    }

    .section {
      padding: 76px 0;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .featured-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .featured-meta a {
      margin-left: 0;
    }

    .source-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
