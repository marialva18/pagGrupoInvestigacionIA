---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/public/Footer.astro';
import Header from '../../components/public/Header.astro';
import { richTextToParagraphs } from '../../lib/rich-text';
import { getPublicNews } from '../../services/api/news.api';

const slug = Astro.params.slug ?? '';
const news = slug ? await getPublicNews(slug).catch(() => null) : null;
const bodyParagraphs = news ? richTextToParagraphs(news.body) : [];

if (!news) {
  Astro.response.status = 404;
}

function formatDate(value: string | null): string {
  if (!value) return 'Fecha pendiente';

  return new Intl.DateTimeFormat('es-PE', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
    timeZone: 'America/Lima',
  }).format(new Date(value));
}
---

<BaseLayout
  title={news ? `${news.title} | INTGARTI` : 'Noticia no encontrada | INTGARTI'}
  description={news?.summary ?? 'Noticia no encontrada.'}
>
  <Header />

  <main class="container article-page">
    {
      news ? (
        <article>
          <div class="meta">
            <span>{news.source.name}</span>

            <span class="meta-separator" aria-hidden="true">
              ·
            </span>

            <time datetime={news.publishedAt ?? undefined}>{formatDate(news.publishedAt)}</time>
          </div>

          <h1>{news.title}</h1>

          <p class="summary">{news.summary}</p>

          <div class="body">
            {bodyParagraphs.length > 0
              ? bodyParagraphs.map((paragraph) => <p>{paragraph}</p>)
              : news.summary && <p>{news.summary}</p>}
          </div>

          {news.origin === 'EXTERNAL' && news.source.url && (
            <aside class="external-source">
              <strong>Publicación externa</strong>

              <p>
                Síntesis editorial elaborada por INTGARTI a partir del título y del extracto
                proporcionados por {news.source.name} mediante su RSS, API o metadatos públicos. El
                contenido se revisa antes de publicarse y no sustituye a la fuente original.
              </p>

              {news.source.originalTitle && (
                <small>Título original: {news.source.originalTitle}</small>
              )}

              <a href={news.source.url} target="_blank" rel="noopener noreferrer">
                Ir a la publicación original →
              </a>
            </aside>
          )}

          <a class="back" href="/noticias">
            ← Volver al historial
          </a>
        </article>
      ) : (
        <section class="not-found">
          <span>404</span>
          <h1>La noticia no fue encontrada.</h1>
          <a href="/noticias">Volver al historial</a>
        </section>
      )
    }
  </main>

  <Footer />
</BaseLayout>

<style>
  .article-page {
    width: min(calc(100% - 48px), 1180px);
    padding: 70px 0 100px;
  }

  article {
    display: grid;
    width: min(100%, 860px);
    margin-inline: auto;
    gap: 26px;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 9px;
    color: var(--color-muted);
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .meta span:first-child {
    color: var(--color-burgundy);
    letter-spacing: 0.08em;
  }

  .meta-separator {
    color: var(--color-line);
  }

  .meta time {
    color: var(--color-muted);
  }

  h1 {
    width: 100%;
    max-width: 860px;
    margin: 0;
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: clamp(2.35rem, 4vw, 3.75rem);
    font-weight: 500;
    letter-spacing: -0.042em;
    line-height: 1;
  }

  .summary {
    width: 100%;
    margin: 0;
    padding-bottom: 26px;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-muted);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .body {
    display: grid;
    width: 100%;
    gap: 14px;
    padding: 0;
    font-size: 0.96rem;
    line-height: 1.72;
  }

  .body p {
    margin: 0;
  }

  .external-source {
    width: 100%;
    box-sizing: border-box;
    margin: 0;
    padding: 25px 27px;
    border-left: 4px solid var(--color-burgundy);
    background: var(--color-ivory);
  }

  .external-source strong {
    display: block;
    color: var(--color-navy);
  }

  .external-source p {
    margin: 10px 0 0;
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .external-source small {
    display: block;
    margin: 14px 0;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .external-source a,
  .back,
  .not-found a {
    color: var(--color-burgundy);
    font-weight: 700;
    text-decoration: none;
    text-decoration-line: none;
  }

  .external-source a {
    display: inline-block;
    padding-bottom: 2px;
    border-bottom: 1px solid currentColor;
  }

  .back {
    display: inline-block;
    width: fit-content;
    margin-top: 12px;
  }

  .not-found {
    display: grid;
    width: min(100%, 860px);
    min-height: 55vh;
    margin-inline: auto;
    align-content: start;
    gap: 22px;
  }

  .not-found span {
    color: var(--color-burgundy);
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .article-page {
      width: min(calc(100% - 28px), 1180px);
      padding: 52px 0 80px;
    }

    article {
      gap: 22px;
    }

    .meta {
      flex-wrap: wrap;
    }

    h1 {
      font-size: clamp(2rem, 10vw, 2.8rem);
    }

    .summary {
      padding-bottom: 22px;
    }

    .body {
      gap: 12px;
    }

    .external-source {
      padding: 22px;
    }

    .back {
      margin-top: 8px;
    }
  }
</style>
