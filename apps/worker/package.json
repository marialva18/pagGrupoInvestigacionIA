    "@intgarti/contracts": "workspace:*",
    "@intgarti/database": "workspace:*",
    "dotenv": "latest",
    "pino": "latest",
    "sharp": "^0.35.3",
    "zod": "latest",
    "@intgarti/news-ingestion": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "typescript": "6.0.3",
    "typescript-eslint": "latest"
  }
}
