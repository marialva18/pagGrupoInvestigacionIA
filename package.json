{
  "name": "intgarti-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <27",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @intgarti/web dev",
    "dev:api": "pnpm --filter @intgarti/api dev",
    "dev:worker": "pnpm --filter @intgarti/worker dev",
    "build": "turbo build",
    "check": "turbo check",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @intgarti/database prisma:generate",
    "db:validate": "pnpm --filter @intgarti/database prisma:validate",
    "db:format": "pnpm --filter @intgarti/database prisma:format",
    "docker:up": "docker compose up --build",
    "docker:watch": "docker compose up --watch",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "pnpm --filter @intgarti/database prisma:migrate:deploy",
    "db:migrate:dev": "pnpm --filter @intgarti/database prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @intgarti/database prisma:migrate:deploy",
    "db:seed": "pnpm --filter @intgarti/database prisma:seed",
    "db:studio": "pnpm --filter @intgarti/database prisma:studio",
    "start:render": "node scripts/start-render.mjs"
  },
  "devDependencies": {
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "6.0.3",
    "@types/node": "^26.1.1",
    "prettier-plugin-astro": "^0.14.1"
  },
  "packageManager": "pnpm@11.13.1"
}
