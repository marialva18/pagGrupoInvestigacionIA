{
  "output": {
    "filePath": "paggrupoinvestigacionia.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true,
    "topFilesLength": 100
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "design/**",
      "docs/**",
      "frontend/node_modules/**",
      "backend/node_modules/**",
      "node_modules/**",
      "frontend/dist/**",
      "backend/dist/**",
      "dist/**",
      ".env*",
      "build/**",
      "coverage/**",
      ".next/**",
      ".vercel/**",
      ".netlify/**",
      ".turbo/**",
      ".vite/**",
      ".cache/**",
      ".repomix-cache/**",
      "repomix-output*",
      "umari-os.*",
      "frontend/src/assets/**",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      "bun.lockb",
      "!*.env.example",
      "*.log",
      "npm-debug.log*",
      "yarn-debug.log*",
      "yarn-error.log*",
      "pnpm-debug.log*",
      ".DS_Store",
      "Thumbs.db",
      ".idea/**",
      ".vscode/**",
      "*.local",
      "*.pem",
      "*.key",
      "*.crt",
      "credentials/**",
      "secrets/**",
      "tmp/**",
      "temp/**",
      "*.zip",
      "*.rar",
      "*.7z",
      "*.tar",
      "*.gz",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.webp",
      "*.ico",
      "*.svg",
      "database/**"
    ]
  },
  "security": {
    "enableSecurityCheck": false
  }
}